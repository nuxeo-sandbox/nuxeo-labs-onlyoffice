<!-- See documentation at http://doc.nuxeo.com/x/HgIz -->
<package type="addon" name="nuxeo-labs-onlyoffice" version="@VERSION@">
  <title>ONLYOFFICE Document Editor Integration</title>
  <description>
    <p>Use ONLYOFFICE to seamlessly edit documents from the Nuxeo Platform</p>
  </description>
  <home-page>https://github.com/nuxeo-sandbox/nuxeo-labs-onlyoffice</home-page>
  <vendor>Nuxeo</vendor>
  <installer restart="true" />
  <uninstaller restart="true" />
  <nuxeo-validation>none</nuxeo-validation>
  <production-state>testing</production-state>
  <supported>false</supported>
  <target-platform>
    <name>lts</name>
    <version>[@NUXEO_TARGET_VERSION@,)</version>
  </target-platform>
  <license>Apache License, Version 2.0</license>
  <license-url>http://www.apache.org/licenses/LICENSE-2.0</license-url>
  <visibility>PUBLIC</visibility>
</package>
