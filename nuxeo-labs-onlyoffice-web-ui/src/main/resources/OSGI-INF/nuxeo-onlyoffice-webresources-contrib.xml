<?xml version="1.0"?>
<component name="nuxeo.labs.onlyoffice.web.ui.resources.contrib">

  <!-- Register the bundle entry-point HTML as a web resource -->
  <extension target="org.nuxeo.ecm.platform.WebResources" point="resources">
    <resource name="nuxeo-onlyoffice.html" type="import">
      <uri>/ui/nuxeo-onlyoffice/nuxeo-onlyoffice.html</uri>
    </resource>
  </extension>

  <!-- Append our bundle to the web-ui Web Resources bundle -->
  <extension target="org.nuxeo.ecm.platform.WebResources" point="bundles">
    <bundle name="web-ui">
      <resources append="true">
        <resource>nuxeo-onlyoffice.html</resource>
      </resources>
    </bundle>
  </extension>
</component>